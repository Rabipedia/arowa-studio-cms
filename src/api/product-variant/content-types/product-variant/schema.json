{
  "kind": "collectionType",
  "collectionName": "product_variants",
  "info": {
    "singularName": "product-variant",
    "pluralName": "product-variants",
    "displayName": "ProductVariant"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product",
      "inversedBy": "variants"
    },
    "sku": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "attributeValues": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::attribute-value.attribute-value",
      "mappedBy": "productVariants"
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "discountPrice": {
      "type": "decimal"
    },
    "stock": {
      "type": "integer",
      "required": true,
      "default": 0
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "isDefault": {
      "type": "boolean",
      "default": false
    },
    "weight": {
      "type": "decimal"
    }
  }
}
